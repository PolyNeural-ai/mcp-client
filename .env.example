# Polyneural AI MCP Client Environment Variables
# Copy this file to .env and fill in your values

# Required: Your Polyneural AI API key
POLYNEURAL_API_KEY=kg_your_api_key_here

# Optional: API base URL (defaults to staging)
POLYNEURAL_API_URL=https://polyneural.ai/mcp

# Optional: Enable debug logging (1 to enable, 0 or unset to disable)
DEBUG=0

# Optional: HTTP request timeout in milliseconds (default: 30000)
REQUEST_TIMEOUT_MS=30000
