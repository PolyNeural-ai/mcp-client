# Polyneural AI MCP Client Environment Variables
# Copy this file to .env and fill in your values

# Required: Your Polyneural AI API key
POLYNEURAL_API_KEY=kg_your_api_key_here

# Optional: API base URL (default: production API)
# Examples:
#   Production: https://api.polyneural.ai/mcp
#   Staging:    https://api-staging.polyneural.ai/mcp
#   Local:      http://localhost:8787/mcp
POLYNEURAL_API_URL=https://api.polyneural.ai/mcp

# Optional: Enable debug logging (1 to enable, 0 or unset to disable)
DEBUG=0

# Optional: HTTP request timeout in milliseconds (default: 30000)
REQUEST_TIMEOUT_MS=30000

# Optional: Enable embedded short-term memory in tool descriptions (true/false, default: false)
# When enabled, the most recent 3 entities with their relations are embedded in the
# get_short_term_memory tool description for immediate context without requiring a tool call
SHORT_TERM=false
